# S2T 后端配置文件
# 复制此文件为 config.yaml 并根据实际环境修改
# 也可通过前端「系统设置」页面在线修改，无需手动编辑此文件

asr:
  engine: funasr
  # FunASR 模型路径（留空则首次运行时自动从 ModelScope 下载到 ~/.cache/modelscope/）
  model: ""
  spk_model: ""
  vad_model: ""
  punc_model: ""
  max_concurrent: 2
  device: cpu  # cpu（推荐，无需 GPU）/ cuda（需 NVIDIA GPU）

llm:
  # provider: llamacpp / aliyun / deepseek
  provider: llamacpp
  llamacpp:
    base_url: http://localhost:8081/v1
    model: Qwen3.6-35B-A3B-UD-Q4_K_M.gguf
    api_key: ""
  aliyun:
    base_url: https://dashscope.aliyuncs.com/compatible-mode/v1
    model: qwen-plus
    api_key: ""  # 或设置环境变量 ALIYUN_API_KEY
  deepseek:
    base_url: https://api.deepseek.com/v1
    model: deepseek-chat
    api_key: ""  # 或设置环境变量 DEEPSEEK_API_KEY

audio:
  sample_rate: 16000
  chunk_duration: 0.5
  supported_formats:
    - wav
    - mp3
    - m4a
    - flac
    - ogg

database:
  path: ./data/s2t.db

storage:
  upload_dir: ./data/uploads

video:
  yt_dlp_path: "yt-dlp"
  sample_interval: 30
  max_duration: 3600
  browser_timeout: 300
  temp_dir: "./data/video_temp"

multimodal:
  # 用于视频截图理解、图文混合分析
  # provider: dashscope / deepseek / openrouter / custom
  provider: dashscope
  base_url: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  model: "qwen-vl-max"
  api_key: ""
  max_tokens: 2048
